# ─────────────────────────────────────────────────────────────
#  AI Code Reviewer v3 — Environment Configuration
#  cp .env.example .env   then fill in your real values.
#  NEVER commit .env to git — it is in .gitignore.
# ─────────────────────────────────────────────────────────────

APP_NAME="AI Code Reviewer"
APP_VERSION="2.0.0"
DEBUG=false
MOCK_MODE=false

HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ── LLM Providers — add at least one ────────────────────────
# Free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
# Free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
# https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

PRIMARY_MODEL=gemini-2.5-pro
FALLBACK_MODEL=gemini-2.5-flash
GROQ_MODEL=llama3-70b-8192
OPENROUTER_MODEL=anthropic/claude-3-haiku

LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_TEMPERATURE=0.0

MAX_CODE_LENGTH=20000
MAX_PROBLEM_LENGTH=5000
MAX_IMAGE_SIZE_MB=10

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── PostgreSQL + pgvector ────────────────────────────────────
DATABASE_URL=postgresql://reviewer:reviewer@localhost:5432/code_reviewer

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_FREE_RPM=10
RATE_LIMIT_PRO_RPM=60
RATE_LIMIT_ENTERPRISE_RPM=600
DEFAULT_TENANT_API_KEY=dev-key-local

# ── Circuit Breaker ───────────────────────────────────────────
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT_S=30
CB_HALF_OPEN_MAX_CALLS=2

# ── Semantic Cache ────────────────────────────────────────────
CACHE_SIMILARITY_THRESHOLD=0.93
CACHE_TTL_HOURS=24
EMBEDDING_MODEL=models/embedding-001

# ── GitHub Webhook ────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=your_github_pat_here
GITHUB_MAX_FILES_PER_PR=10
GITHUB_MAX_FILE_BYTES=50000

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
